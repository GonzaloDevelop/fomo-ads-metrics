# Supabase
NEXT_PUBLIC_SUPABASE_URL=https://xxxxx.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=eyJhbGciOi...
SUPABASE_SERVICE_ROLE_KEY=eyJhbGciOi...

# Encryption key for Meta/Google tokens stored in DB (64-char hex = 32 bytes for AES-256)
# Generate: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
ENCRYPTION_KEY=

# Google Ads API
# 1. Create OAuth credentials at https://console.cloud.google.com/apis/credentials
# 2. Enable "Google Ads API" at https://console.cloud.google.com/apis/library/googleads.googleapis.com
# 3. Get Developer Token from MCC: Tools & Settings > Setup > API Center
GOOGLE_ADS_CLIENT_ID=
GOOGLE_ADS_CLIENT_SECRET=
GOOGLE_ADS_DEVELOPER_TOKEN=
GOOGLE_ADS_REDIRECT_URI=http://localhost:3001/api/google/callback

# Owner email (first user with this email gets 'owner' role automatically)
OWNER_EMAIL=

# App
NEXT_PUBLIC_APP_NAME=Fomo Ads Metrics
